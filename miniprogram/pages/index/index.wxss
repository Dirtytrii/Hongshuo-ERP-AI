.header {
  display: flex;
  justify-content: space-between;
  align-items: center;
  margin-bottom: 24rpx;
}
.header .title { font-size: 36rpx; font-weight: bold; color: #166534; }
.header .link { font-size: 26rpx; color: #16a34a; }
.loading, .error { padding: 48rpx; text-align: center; color: #6b7280; }
.error { color: #dc2626; }
.row {
  display: flex;
  justify-content: space-between;
  align-items: center;
  padding: 16rpx 0;
  border-bottom: 1rpx solid #f3f4f6;
}
.row:last-child { border-bottom: none; }
.warn { color: #dc2626; font-size: 24rpx; }
.btn-primary {
  background: #16a34a;
  color: #fff;
  border-radius: 12rpx;
  margin-top: 24rpx;
  font-size: 28rpx;
}
