page {
  font-family: -apple-system, BlinkMacSystemFont, 'Segoe UI', Roboto, sans-serif;
  font-size: 28rpx;
  color: #333;
  box-sizing: border-box;
}

.container {
  padding: 24rpx;
  min-height: 100vh;
}

.card {
  background: #fff;
  border-radius: 16rpx;
  padding: 24rpx;
  margin-bottom: 24rpx;
  box-shadow: 0 2rpx 12rpx rgba(0,0,0,0.06);
}

.title {
  font-size: 32rpx;
  font-weight: bold;
  color: #166534;
  margin-bottom: 16rpx;
}

.text-muted {
  color: #6b7280;
  font-size: 24rpx;
}
